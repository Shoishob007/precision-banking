{
  "name": "precision-editorial-banking-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:init": "tsx src/db/init.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:init && npm run db:migrate && npm run db:seed",
    "load:test": "npx artillery@2.0.20 run load-tests/artillery-transactions.yml",
    "load:test:report": "node -e \"require('fs').mkdirSync('load-tests/results',{recursive:true})\" && npx artillery@2.0.20 run --output load-tests/results/artillery-report.json load-tests/artillery-transactions.yml",
    "load:test:html": "npx artillery@2.0.20 report --output load-tests/results/artillery-report.html load-tests/results/artillery-report.json",
    "load:validate": "node load-tests/validate-consistency.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.2",
    "artillery": "^2.0.20",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
